# Database
DATABASE_URL="postgresql://user:password@localhost:5432/salva-contas?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-here"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_REDIRECT_URL="https://salva-contas.vercel.app"

# Gemini AI
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_TRANSACTION_MODEL="gemini-2.5-flash"
GEMINI_TRANSACTION_FALLBACK_MODELS="gemini-1.5-flash,gemini-2.0-flash-lite"
GEMINI_TRANSACTION_MODELS="gemini-2.5-flash,gemini-3-flash,gemini-1.5-flash,gemini-2.0-flash-lite"
GEMINI_TRANSACTION_MODEL_COOLDOWN_MS="15000"

# Groq AI (OpenAI-compatible endpoint)
GROQ_API_KEY="your-groq-api-key-here"
GROQ_BASE_URL="https://api.groq.com/openai/v1/chat/completions"
GROQ_TRANSACTION_MODELS="meta-llama/llama-4-scout-17b-16e-instruct"
GROQ_TRANSACTION_MODEL_COOLDOWN_MS="15000"

# GenAI routing order
GEN_AI_PROVIDER_ORDER="groq,gemini"

# Cloudflare R2 Storage
R2_ACCOUNT_ID="your_account_id_from_cloudflare_dashboard"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="salva-contas-private"
R2_ENDPOINT="https://xxxxxx.r2.cloudflarestorage.com"
